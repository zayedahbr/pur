# ================================================================
# PUREWERK — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# Sur Vercel : ajoute-les dans Project Settings → Environment Variables
# ================================================================

# --- SUPABASE ---
# Récupère sur https://supabase.com → ton projet → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # ATTENTION : clé privée, jamais côté client

# --- STRIPE ---
# Récupère sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx        # sk_live_ en production
STRIPE_WEBHOOK_SECRET=whsec_xxxxx      # créé après config du webhook
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx   # utilisée côté client (peut être publique)

# --- RESEND (emails) ---
# Récupère sur https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=PureWerk <commandes@tondomaine.fr>   # nécessite domaine vérifié dans Resend
EMAIL_REPLY_TO=contact@tondomaine.fr

# --- SITE ---
SITE_URL=https://tondomaine.fr
SITE_NAME=PureWerk
